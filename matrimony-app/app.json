{
  "expo": {
    "name": "Ayya Matrimony",
    "slug": "matrimony-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "matrimony",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#570000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.matrimony.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#570000"
      },
      "package": "com.matrimony.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Ayya Matrimony to access your photos to upload profile pictures.",
          "cameraPermission": "Allow Ayya Matrimony to use your camera to take profile pictures."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
